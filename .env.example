# =============================================================================
# Plotline Monorepo — Environment Variables
# Copy to .env at the repo root for local development.
# App-specific vars may also live in apps/plotline/.env.local and apps/payload/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Payload CMS (apps/payload)
# -----------------------------------------------------------------------------
PAYLOAD_SECRET=change-me-to-a-long-random-string
PAYLOAD_API_KEY=change-me-to-a-service-api-key-for-bff-calls

# Plotline app URL — used by Payload for CORS (production + preview URLs)
PLOTLINE_URL=http://localhost:3000

# Clerk webhook secret
CLERK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Plotline app (apps/plotline)
# -----------------------------------------------------------------------------
# Payload REST API base URL (no trailing slash)
PAYLOAD_URL=http://localhost:3001

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# TMDB read access token (server-side only; JWT from TMDB API settings)
TMDB_READ_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Sentry (both apps — use separate projects or environment tags)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
