# Payload app environment variables
# Copy to apps/payload/.env or use repo root .env (see ../../.env.example)

DATABASE_URL=postgresql://plotline:plotline@localhost:5432/plotline
POSTGRES_URL=
PAYLOAD_SECRET=change-me-to-a-long-random-string
PAYLOAD_API_KEY=change-me-to-a-service-api-key-for-bff-calls

# Plotline app URL — used for CORS
PLOTLINE_URL=http://localhost:3000
PAYLOAD_URL=http://localhost:3001

# Clerk webhook (profile sync)
CLERK_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
